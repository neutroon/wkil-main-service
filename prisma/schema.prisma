// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  // output   = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id                  Int       @id @default(autoincrement())
  name                String
  email               String    @unique
  password            String
  facebookUserId      String?   @unique
  facebookAccessToken String?
  role                String    @default("user") // "super_admin", "admin", "manager", "user"
  isActive            Boolean   @default(true) // Soft delete flag
  deletedAt           DateTime? // When user was deactivated
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Identity Lifecycle (Production Grade)
  isEmailVerified        Boolean   @default(false)
  emailVerificationToken String?   @unique
  passwordResetToken     String?   @unique
  passwordResetExpires   DateTime?
  lastVerificationSentAt DateTime?

  // Management relationships
  managedUsers  UserManagement[] @relation("ManagerRelations")
  managedBy     UserManagement[] @relation("UserRelations")
  assignedUsers UserManagement[] @relation("AssignerRelations")

  // Existing relations
  facebookAccounts  FacebookAccount[]
  analytics         UserAnalytics[]
  whatsAppAccounts  WhatsAppAccount[]

  // Business profile creation
  isBusinessProfileCreated Boolean           @default(false)
  businessProfiles         BusinessProfile[]
  widgetInstalls           WidgetInstall[]
  contentPlans             ContentPlan[]
  aiUsageStats             AiUsageStat[]
  aiCallLogs               AiCallLog[]
  billingFailureLogs       BillingFailureLog[]
  mediaAssets              BusinessProfileMedia[]

  // User-Centric Billing (Production Grade)
  plan                String    @default("FREE") // "FREE", "PRO", "ENTERPRISE"
  monthlyTokensUsed   Int       @default(0)     // Aggregated usage across all businesses
  monthlyCreditsUsed  Int       @default(0)     // New Credit-based tracking
  monthlyQuota        Int?                      // Individual hard-ceiling override (tokens)
  monthlyCreditQuota  Int?                      // Individual hard-ceiling override (Credits)
  autoResetEnabled    Boolean   @default(true)  // Resets usage at start of month
  
  // Refresh Token Rotation (Production Grade)
  refreshTokenHash         String?   @unique
  refreshTokenExpiresAt    DateTime?
  previousRefreshTokenHash String?   @unique
  rotatedAt               DateTime?
}

model BusinessProfile {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                String
  responseMode        String   @default("AUTO") // "AUTO", "REVIEW_ALL", "MANUAL"
  identity            String
  targetAudience      String
  voice               String   @default("Professional")
  tone                String   @default("Friendly")
  productsServices    String[]
  expectedUserIntents String[]
  corePolicies        String?
  phoneNumbers        String[]
  workingHours        String?
  address             String?
  leadCaptureInstructions String? @default("Captures a prospective lead's information. Trigger this ONLY when the user explicitly expresses strong buying intent, asks for a callback, tells you their contact details, or wants to proceed with an action.")
  aiBehaviorInstructions String?
  followUpEnabled      Boolean  @default(false)
  followUpMode         String   @default("AUTO") // "AUTO" = AI decides from chat context, "CUSTOM" = use extra admin guidance
  followUpDelays       Json?
  followUpInstructions String?
  
  // Brand Kit & Visual DNA
  brandLogoUrl           String?
  brandPrimaryColor     String?
  brandSecondaryColor   String?
  brandAccentColor      String?
  visualAesthetic       String?   // The Vibe (e.g., KHALEEJI_LUXURY)
  artStyle             String?   // The Rendering (e.g., REALISTIC)
  brandKitCompleted    Boolean   @default(false)
  brandKitUpdatedAt    DateTime?
  brandWatermarkEnabled Boolean   @default(true)
  watermarkPosition     WatermarkPosition @default(BOTTOM_RIGHT)

  // Facebook Comment Settings
  facebookGreetingMode     String @default("AI") // "AI", "TEMPLATE"
  facebookGreetingTemplate String @default("Thanks {{name}}! I've sent the full details to your inbox.")

  scrapedWebsiteUrl String?
  scrapedMarkdown   String?

  ragIngested   Boolean   @default(false)
  ragIngestedAt DateTime?

  plan                String    @default("FREE") // "FREE", "PRO", "ENTERPRISE"
  monthlyTokensUsed   Int       @default(0)     // Rolling monthly usage for quota checks
  monthlyCreditsUsed  Int       @default(0)     // New Credit-based tracking
  monthlyCreditQuota  Int?                      // Individual hard-ceiling override (Credits)
  autoResetEnabled    Boolean   @default(false) // Whether usage resets automatically at month-start

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  faqs            BusinessProfileFaq[]
  chunks          BusinessProfileChunk[]
  facebookPages   FacebookPage[]
  whatsAppAccounts WhatsAppAccount[]
  crmIntegrations CrmIntegration[]
  externalDataSources ExternalDataSource[]
  widgetInstalls    WidgetInstall[]
  conversations     Conversation[]
  aiUsageStats      AiUsageStat[]
  aiCallLogs        AiCallLog[]
  billingFailureLogs BillingFailureLog[]
  contentPlans      ContentPlan[]
  knowledgeSections BusinessProfileKnowledgeSection[]
  mediaAssets       BusinessProfileMedia[]
}

/// Embeddable web chat widget: publicSiteKey is sent from the browser; allowedOrigins is a JSON array of exact Origin strings (e.g. ["https://shop.example.com"]).
model WidgetInstall {
  id                Int             @id @default(autoincrement())
  userId            Int
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfileId Int
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  publicSiteKey     String          @unique
  allowedOrigins    Json
  label             String?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([userId])
  @@index([businessProfileId])
}

model ExternalDataSource {
  id                Int             @id @default(autoincrement())
  businessProfileId Int
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  
  name              String          // e.g., "Product Catalog", "Room Availability"
  description       String          // e.g., "Search for available tech products" - Used by Gemini to know when to use the tool
  apiUrl            String          // The GET endpoint, e.g., "https://api.store.com/products"
  method            String          @default("GET")
  headers           Json?           // Optional API keys or Bearer tokens
  queryParams       Json?           // Optional required query params expected by the API
  routingMode       String          @default("STRICT") // STRICT = semantic pre-router, FAST = expose when active
  routerTimeoutMs   Int             @default(2500) // Max wait for STRICT semantic routing before falling back
  
  // Defines the schema the AI is allowed to pass to the API (e.g. { category: "string", limit: "integer" })
  expectedParamsSchema Json?        

  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([businessProfileId])
}

model BusinessProfileFaq {
  id         Int             @id @default(autoincrement())
  businessId Int
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  question String
  answer   String

  @@index([businessId])
}

model BusinessProfileKnowledgeSection {
  id         Int             @id @default(autoincrement())
  businessId Int
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  title   String
  content String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

model BusinessProfileChunk {
  id                Int                        @id @default(autoincrement())
  businessProfileId Int
  businessProfile   BusinessProfile            @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  content           String
  chunkType         String
  // raw_content | identity | product | contact | faq | intents
  embedding         Unsupported("vector(768)")
  chunkIndex        Int
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([businessProfileId])
  @@index([businessProfileId, chunkType]) // fast filtered deletes
}

model CrmIntegration {
  id                Int             @id @default(autoincrement())
  businessProfileId Int
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  provider          String          // e.g., "hubspot", "gohighlevel", "webhook"
  apiKey            String?         // Optional: generic storage for CRM keys
  webhookUrl        String?         // Optional: for custom integrations or Zapier/Make
  fieldMapping      Json?           // Optional configuration for mapping fields
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([businessProfileId])
}

model CrmDeliveryLog {
  id                Int      @id @default(autoincrement())
  businessProfileId Int
  integrationId     Int
  idempotencyKey    String
  leadKey           String
  payloadHash       String
  eventType         String   // "lead_created" | "lead_updated"
  status            String   @default("PENDING") // "PENDING" | "DELIVERED" | "FAILED" | "SKIPPED_DUPLICATE"
  attempts          Int      @default(0)
  lastError         String?
  deliveredAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([businessProfileId, integrationId, idempotencyKey])
  @@index([businessProfileId, integrationId, leadKey, status])
  @@index([businessProfileId, integrationId, payloadHash, status])
}

model Conversation {
  id                Int      @id @default(autoincrement())
  pageId            String
  senderId          String   // Facebook PSID or WhatsApp phone (raw)
  businessProfileId Int
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  /// "whatsapp" | "messenger" | "web" | "facebook_comment" — null means legacy/untagged
  channel           String?
  /// Human-readable customer phone for WhatsApp conversations
  customerPhone     String?
  customerName      String?
  customerAvatar    String?
  status            String   @default("OPEN") // "OPEN", "RESOLVED", "SNOOZED"
  aiEnabled         Boolean  @default(true)   // Toggle automation for this specific thread
  
  // Facebook Comments / Thread Continuity
  externalId        String?  @unique // Facebook comment_id or similar
  postId            String?  // The source post ID (for context header)
  postUrl           String?  // Clickable link to original FB post
  sourceCommentText String?  // The raw triggering comment text (for agent context)
  processingStatus  String   @default("COMPLETED") // "PENDING", "COMPLETED", "FAILED"
  parentConversationId Int?
  parentConversation   Conversation? @relation("ThreadContinuity", fields: [parentConversationId], references: [id])
  childConversations   Conversation[] @relation("ThreadContinuity")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  readAt            DateTime? // When the business team last read this conversation

  messages ConversationMessage[]

  @@index([pageId, senderId])
  @@index([pageId, senderId, updatedAt])
  @@index([channel])
  @@index([externalId])
  @@index([postId])
}

model ConversationMessage {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "model" | "agent"
  content        String
  type           String       @default("text") // "text", "image", "video", "audio", "voice", "document", "sticker"
  mediaId        String?      // Meta media_id
  mediaMetadata  Json?        // Stores duration, filename, mimeType, size etc.
  externalId     String?      @unique // Meta message ID (wamid or mid) for status tracking
  status         String       @default("SENT") // "SENT", "DELIVERED", "READ", "PENDING_REVIEW", "EDITED_AND_SENT", "FAILED"
  aiReasoning    String?      // Storing the AI's thought process for routing
  handoffCategory String?     // e.g. "SALES", "SUPPORT", "ANGRY_CUSTOMER"
  intent          String?     // AI-detected intent (e.g. "SALES_DM", "GREET_ONLY")
  isPrivate       Boolean     @default(false)
  origin          String?     // Context tag for converged history (e.g. "facebook_comment_reply")
  createdAt       DateTime    @default(now())

  aiCorrection   AiCorrection?

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([status, createdAt])
  @@index([handoffCategory])
  @@index([externalId])
}

/// Tracks corrections made by humans to AI-generated drafts
model AiCorrection {
  id              Int                 @id @default(autoincrement())
  messageId       Int                 @unique
  message         ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  originalAiText  String
  humanEditedText String
  createdAt       DateTime            @default(now())

  @@index([messageId])
}






/// WhatsApp Business phone number linked to a user
model WhatsAppAccount {
  id                  Int             @id @default(autoincrement())
  userId              Int
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumberId       String          // Meta's permanent phone-number ID
  displayPhoneNumber  String          // Human-readable, e.g. "+1 555 000 1234"
  wabaId              String          // WhatsApp Business Account ID
  accessToken         String          // Encrypted system-user or page access token
  businessProfileId   Int?
  businessProfile     BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  isActive            Boolean         @default(true)
  /// How the number was onboarded: "COEXISTENCE" = stays on WBA app simultaneously;
  /// "BUSINESS_API" = full migration away from the WhatsApp Business App.
  connectionMode      String          @default("BUSINESS_API") // "BUSINESS_API" | "COEXISTENCE"
  isTokenValid        Boolean         @default(true)  // Result of the last /debug_token check
  lastValidatedAt     DateTime?       // When the token was last checked for health
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([userId, phoneNumberId])
  @@index([userId])
  @@index([phoneNumberId])
  @@index([businessProfileId])
}

model UserManagement {
  id         Int      @id @default(autoincrement())
  managerId  Int // The manager/admin
  userId     Int // The user being managed
  assignedAt DateTime @default(now())
  assignedBy Int // Who assigned this relationship
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  manager  User @relation("ManagerRelations", fields: [managerId], references: [id], onDelete: Cascade)
  user     User @relation("UserRelations", fields: [userId], references: [id], onDelete: Cascade)
  assigner User @relation("AssignerRelations", fields: [assignedBy], references: [id], onDelete: Cascade)

  @@unique([managerId, userId])
  @@index([managerId])
  @@index([userId])
  @@index([assignedBy])
}

model Lead {
  id        Int      @default(autoincrement())
  name      String
  email     String   @unique
  url       String?
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FacebookAccount {
  id             Int       @id @default(autoincrement())
  userId         Int
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  facebookUserId String    @unique
  name           String?
  pictureUrl     String?
  accessToken    String
  tokenType      String    @default("bearer")
  expiresAt      DateTime?
  refreshToken   String?
  scope          String?
  isActive       Boolean   @default(true)
  isTokenValid   Boolean   @default(true)
  lastValidatedAt DateTime?
  lastUsedAt     DateTime?
  deviceInfo     String? // Store device/browser info for device management
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  pages      FacebookPage[]
  activities FacebookActivity[]

  @@index([userId])
  @@index([facebookUserId])
}

model FacebookPage {
  id                Int             @id @default(autoincrement())
  facebookAccountId Int
  facebookAccount   FacebookAccount @relation(fields: [facebookAccountId], references: [id], onDelete: Cascade)

  pageId          String
  pageName        String
  pageAccessToken String
  category        String?
  pictureUrl      String?
  followersCount  Int       @default(0)
  isActive        Boolean   @default(true)
  isTokenValid    Boolean   @default(true)
  webhookStatus   String    @default("PENDING") // PENDING | SUBSCRIBED | FAILED
  webhookCheckedAt DateTime?
  lastValidatedAt DateTime?
  lastUsedAt      DateTime?

  // Per-Page Automation Overrides
  responseMode          String   @default("AUTO") // "AUTO", "REVIEW_ALL", "MANUAL"
  commentAutoDmEnabled  Boolean  @default(false)  // Automatic private DM to commenters
  commentPublicGreeting String   @default("Thanks {{name}}! I've sent the details to your inbox.")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  activities        FacebookActivity[]
  businessProfile   BusinessProfile?   @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  businessProfileId Int?

  @@unique([facebookAccountId, pageId])
  @@index([pageId])
  @@index([businessProfileId])
}

model FacebookActivity {
  id                Int             @id @default(autoincrement())
  facebookAccountId Int
  facebookAccount   FacebookAccount @relation(fields: [facebookAccountId], references: [id], onDelete: Cascade)
  facebookPageId    Int?
  facebookPage      FacebookPage?   @relation(fields: [facebookPageId], references: [id], onDelete: SetNull)
  activityType      String // 'post_created', 'post_scheduled', 'comment_replied', 'page_connected', etc.
  activityData      Json? // Store additional activity-specific data
  success           Boolean         @default(true)
  errorMessage      String?
  createdAt         DateTime        @default(now())

  @@index([facebookAccountId])
  @@index([activityType])
  @@index([createdAt])
}

model UserAnalytics {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  postsCreated    Int      @default(0)
  postsScheduled  Int      @default(0)
  commentsReplied Int      @default(0)
  pagesConnected  Int      @default(0)
  totalEngagement Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model AiUsageStat {
  id                Int             @id @default(autoincrement())
  userId            Int
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfileId Int             @default(0)
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  date              DateTime        @db.Date
  modelName         String          @default("gemini-2.0-flash")
  
  promptTokens      Int             @default(0)
  completionTokens  Int             @default(0)
  totalTokens       Int             @default(0)
  apiCalls          Int             @default(0)
  
  // Production-grade additions
  groundingCalls    Int             @default(0) 
  embeddingTokens   Int             @default(0)
  systemCost        Float           @default(0) // Locked-in cost at time of usage (your cost)
  customerCost      Float           @default(0) // What you charged the workspace
  multiplier        Float           @default(1.0) // Snapshot of the multiplier at record time

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([userId, businessProfileId, date, modelName])
  @@index([userId])
  @@index([businessProfileId])
  @@index([date])
}

model AiCallLog {
  id                String   @id @default(cuid())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfileId Int      @default(0)
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  
  conversationId    String?
  modelName         String
  operation         String   // "messenger_reply", "whatsapp_reply", "rag_embedding", "crm_enrichment"
  
  promptTokens      Int      @default(0)
  completionTokens  Int      @default(0)
  embeddingTokens   Int      @default(0)
  groundingCalls    Int      @default(0)
  
  systemCost        Float    @default(0)
  customerCost      Float    @default(0)
  multiplier        Float    @default(0)
  
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([businessProfileId, createdAt])
  @@index([conversationId])
}

model BillingFailureLog {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfileId Int      @default(0)
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  
  modelName         String?
  promptTokens      Int?
  completionTokens  Int?
  embeddingTokens   Int?
  groundingCalls    Int?
  
  error             String
  operation         String?
  
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([businessProfileId])
  @@index([createdAt])
}

/// Global system settings for configurations like billing multipliers
model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentPlan {
  id                Int      @id @default(autoincrement())
  businessProfileId Int
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate         DateTime
  endDate           DateTime
  goals             String?  // JSON or string (e.g., "Awareness, Lead Gen")
  currentTrends     String?  // Custom context for this specific month/campaign
  status            String   @default("draft") // draft, approved, active, completed
  isGrounded        Boolean  @default(false)
  researchSummary   String?  @db.Text
  posts             ContentPlanPost[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ContentPlanPost {
  id                Int      @id @default(autoincrement())
  contentPlanId     Int
  contentPlan       ContentPlan @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)
  scheduledAt       DateTime
  platform          String   // "facebook", "instagram", "linkedin"
  pillar            String   // The content pillar (e.g. "Behind the scenes")
  topic             String
  format            String   // "image_post", "carousel", "reel", "story"
  caption           String?  @db.Text
  imagePrompt       String?  @db.Text
  imageUrl          String?
  mediaAssetId      Int?
  mediaAsset        BusinessProfileMedia? @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  reelScript        String?  @db.Text // Script for reels/video
  carouselSlides    Json?    // Array of { slideText, slideImagePrompt } for carousels
  status            String   @default("pending") // pending, generated, approved, approved_manual, scheduled, posted
  postedAt          DateTime?
  facebookPostId    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// AI-sendable media assets uploaded by users, stored on Cloudflare R2
model BusinessProfileMedia {
  id                    Int             @id @default(autoincrement())
  businessProfileId     Int
  businessProfile       BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  userId                Int
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Human-facing & AI metadata
  name                  String          // e.g. "2025 Product Catalog"
  instructions          String          @db.Text // e.g. "Send when customer asks for pricing"
  mediaType             String          // "image" | "document" | "video"
  usageScope            String          @default("CHAT_ATTACHMENT") // CHAT_ATTACHMENT | CONTENT_ASSET
  mimeType              String          // e.g. "application/pdf", "image/jpeg"
  fileSizeBytes         Int

  // Storage: Cloudflare R2
  r2Key                 String          // e.g. "media/bp_42/uuid_filename.pdf"
  publicUrl             String          // Public URL for Web Widget delivery

  // Storage: Meta Platform IDs (populated by background job)
  whatsappMediaId       String?
  whatsappMediaExpiresAt DateTime?       // WhatsApp IDs expire after ~30 days
  messengerAttachmentId String?         // Reusable — does not expire

  // Sync status per platform (Legacy — migrated to BusinessProfileMediaSync)
  whatsappSyncStatus    String          @default("PENDING") // PENDING | SYNCED | FAILED | EXPIRED
  messengerSyncStatus   String          @default("PENDING")

  // Lifecycle (soft-delete — never hard-delete to preserve historical messages)
  isActive              Boolean         @default(true)
  deletedAt             DateTime?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  syncs                 BusinessProfileMediaSync[]
  contentPlanPosts      ContentPlanPost[]

  @@index([businessProfileId])
  @@index([userId])
  @@index([isActive, businessProfileId])
  @@index([businessProfileId, usageScope, isActive])
  @@index([whatsappMediaExpiresAt]) // For the refresh scheduler
}

/// Stores specific media IDs per platform identity (PageID or PhoneID)
model BusinessProfileMediaSync {
  id                    Int                  @id @default(autoincrement())
  mediaId               Int
  media                 BusinessProfileMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  
  platform              String               // "messenger" | "whatsapp"
  identifier            String               // PageID or PhoneNumberId (e.g. 1029384756)
  externalMediaId       String               
  expiresAt             DateTime?            // Optional: for WhatsApp IDs
  
  status                String               @default("SYNCED") // SYNCED | FAILED
  lastError             String?              @db.Text
  
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([mediaId, platform, identifier])
  @@index([mediaId])
  @@index([platform, identifier])
}

enum WatermarkPosition {
  TOP_LEFT
  TOP_RIGHT
