{
  "name": "wkil-backend",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "prebuild": "prisma generate",
    "build": "tsc && tsc-alias && redocly bundle docs/openapi.yaml --output dist/openapi.json --ext json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:lint": "redocly lint docs/openapi.yaml",
    "docs:routes": "node scripts/check-openapi-routes.js",
    "docs:bundle": "redocly bundle docs/openapi.yaml --output dist/openapi.json --ext json",
    "docs:check": "npm run docs:lint && npm run docs:routes && npm run docs:bundle",
    "docs:sync": "npm run docs:check && npm run types:api",
    "types:api": "openapi-typescript docs/openapi.yaml -o ../app/src/types/openapi.generated.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@google/genai": "^1.46.0",
    "@langchain/core": "^1.1.41",
    "@langchain/google-genai": "^2.1.30",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@prisma/client": "^6.16.2",
    "@sentry/node": "^10.51.0",
    "@sentry/profiling-node": "^10.51.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.12.2",
    "axios-retry": "^4.5.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.1",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "langsmith": "^0.5.25",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.5",
    "os": "^0.1.2",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@redocly/cli": "^2.31.5",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/socket.io": "^3.0.1",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.10",
    "openapi-typescript": "^7.13.0",
    "prisma": "^6.16.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
