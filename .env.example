GEMINI_API_KEY=your_gemini_api_key_here

# Optional: 32-byte AES key — 64 hex chars (recommended) or base64-encoded 32 bytes.
# When set, Facebook user + page access tokens are encrypted at rest in the database.
# FB_TOKEN_ENCRYPTION_KEY=

# Minimum cosine similarity (0–1) for RAG chunks; weaker matches are dropped.
# RAG_MIN_SIMILARITY=0.25

# Log level: debug | info | warn | error
# LOG_LEVEL=info

# Trust reverse proxy (ngrok, ALB). Default is 1 hop. Set 0 when hitting Node directly with no proxy.
# TRUST_PROXY=1

# ── Identity Lifecycle ────────────────────────────────────
# Nodemailer / SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
MAIL_FROM="PagesPilot <noreply@pagespilot.com>"

# Handshake configuration
FRONTEND_URL=http://localhost:3000
VERIFICATION_TOKEN_SECRET=your_verification_secret_here
PASSWORD_RESET_TOKEN_SECRET=your_reset_secret_here
