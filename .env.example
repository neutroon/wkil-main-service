# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres 
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the 
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.
# development database url
DATABASE_URL=

# production database url
# DATABASE_URL=

FB_API_URL=
FB_APP_ID=
FB_APP_SECRET=
FB_AUTH_APP_ID=
FB_AUTH_APP_SECRET=
MESSENGER_VERIFY_TOKEN=
WHATSAPP_VERIFY_TOKEN=
FB_SYSTEM_USER_ACCESS_TOKEN=
# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Gemini config
# GEMINI_API_KEY=AIzaSyDfLJ_HcsqaEM64iagef4rmZU8IK4mJ6jY
GEMINI_API_KEY=

# Future provider keys — optional. Only Google is wired into the runtime
# today; the other two are here so the AiModel registry can accept non-Google
# rows in advance (they'll be flagged "No API key" in the admin UI and
# skipped by the runtime until the SDK is wired in). NEVER mirror these
# into the AiModel table — env/vault is the only credential store.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
AI_CHAT_RESPONSE_DEADLINE_MS=60000
AI_CHAT_RAG_TIMEOUT_MS=10000
AI_CHAT_PREP_LOOKUP_TIMEOUT_MS=5000

# ── Chat runtime fallback config ─────────────────────────────────────────────
# These vars are SAFETY NETS, not primary config. The admin-managed AiModel
# registry (DB) is the source of truth for chat models. These fire ONLY when
# the registry has zero active chat rows or the DB is unreachable. Ops can
# also use them to override the model set per environment without a DB edit.
# Resolution order: DB (AiModel table) → env → hardcoded defaults in code.
#
# Comma-separated chat model IDs, tried in order (first is the default).
# AI_CHAT_FALLBACK_MODEL_TIERS=gemini-3.1-flash-lite-preview,gemini-3-flash-preview,gemini-2.5-flash
#
# Per-call max output tokens used when the registry's per-model value is
# missing or the registry is unreachable. Range: 256–65536. Default: 8192.
# AI_CHAT_FALLBACK_MAX_OUTPUT_TOKENS=8192

# google cloud config
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Firebase Cloud Messaging (mobile push) ─────────────────────────────────
# The Firebase service account JSON, base64-encoded. Generate at
# https://console.firebase.google.com/project/_/settings/serviceaccounts/adminsdk
# and store the JSON as a Fly secret / Codemagic env var.
# FIREBASE_SERVICE_ACCOUNT_BASE64=
# FCM project ID (usually the same as GOOGLE_CLOUD_PROJECT_ID).
# FIREBASE_PROJECT_ID=
# Set to true ONLY in environments where the service account is provisioned.
# Keeps push calls no-op in CI / unit tests so the rest of the pipeline
# keeps working.
# FCM_ENABLED=false

# google auth config
GOOGLE_AUTH_CLIENT_ID=

# replica config
REPLICATE_API_TOKEN=

# Redis connection 
REDIS_URL=


NEXT_PUBLIC_API=
NEXT_PUBLIC_APP_ORIGIN=


# cloudflare R2 connections
R2_PUBLIC_URL=
CF_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=

# ── Identity Lifecycle ────────────────────────────────────
# Nodemailer / SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
MAIL_FROM="Wkil <noreply@wkil.app>"

# Handshake configuration
FRONTEND_URL=http://localhost:3000
VERIFICATION_TOKEN_SECRET=your_verification_secret_here
PASSWORD_RESET_TOKEN_SECRET=your_reset_secret_here

# Customer / conversation status sync (bidirectional, fires on every
# status change on either side):
#   customer -> RESOLVED          -> all OPEN conversations -> RESOLVED
#   customer -> ACTIVE            -> all RESOLVED conversations -> OPEN
#   conversation auto-reopens     -> customer may flip RESOLVED -> ACTIVE
#   conversation is last RESOLVED -> customer may flip ACTIVE -> RESOLVED
# ARCHIVED conversations and manual NEEDS_FOLLOW_UP/ARCHIVED customer
# states are preserved.
# Set to "false" to disable the sync — status changes then only happen
# through the customers page.
# CUSTOMER_STATUS_AUTO_FROM_CONVERSATIONS=true
